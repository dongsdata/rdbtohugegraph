# ══════════════════════════════════════════════════════════════
# RDB → HugeGraph 적재 파이프라인 - 접속 정보
#
# 1. 이 파일을 복사해서 .env 로 만드세요:
#      cp .env.example .env
# 2. 본인 환경에 맞게 값을 수정하세요.
# 3. .env 는 Git에 올라가지 않습니다 (.gitignore 참고).
# ══════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=postgres
PG_SCHEMA=public
PG_USER=postgres
PG_PASSWORD=

# ── HugeGraph ─────────────────────────────────────────────────
HG_HOST=localhost
HG_PORT=8080
HG_GRAPHSPACE=DEFAULT
HG_GRAPH=hugegraph
HG_USER=admin
HG_PASSWORD=

# ── 파이프라인 설정 ───────────────────────────────────────────
# 배치당 처리 행 수 (서버 불안정 시 작은 값으로 조정)
BATCH_SIZE=100
